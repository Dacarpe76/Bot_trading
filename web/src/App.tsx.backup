import React, { useState, useEffect, useRef, Component, ErrorInfo } from 'react';
import { Layout, Activity, Zap, History, TrendingUp, ArrowUpRight, ArrowDownRight, Clock } from 'lucide-react';
import { motion, AnimatePresence } from 'framer-motion';
import axios from 'axios';

// --- Error Boundary ---
class ErrorBoundary extends Component<{ children: React.ReactNode }, { hasError: boolean, error: Error | null, errorInfo: ErrorInfo | null }> {
  constructor(props: any) {
    super(props);
    this.state = { hasError: false, error: null, errorInfo: null };
  }

  static getDerivedStateFromError(error: Error) {
    return { hasError: true, error };
  }

  componentDidCatch(error: Error, errorInfo: ErrorInfo) {
    console.error(\"Uncaught error:\", error, errorInfo);
    this.setState({ errorInfo });
  }

  render() {
    if (this.state.hasError) {
      return (
        <div className=\"p-8 text-red-500 bg-black min-h-screen font-mono\">
          < h1 className =\"text-2xl font-bold mb-4 border-b border-red-900 pb-2\">CRITICAL UI ERROR</h1>
            < div className =\"bg-red-900/10 p-4 rounded border border-red-900/50 mb-4\">
              < p className =\"font-bold\">{this.state.error?.toString()}</p>
          </div >
        <details className=\"bg-gray-900 p-4 rounded overflow-auto border border-white/10\">
          < summary className =\"cursor-pointer text-gray-400 mb-2\">View Stack Trace</summary>
            < pre className =\"text-xs text-gray-500 whitespace-pre-wrap\">
      { this.state.errorInfo?.componentStack }
            </pre >
          </details >
        <button
          onClick={() => window.location.reload()}
          className=\"mt-8 px-4 py-2 bg-red-600 text-white rounded hover:bg-red-500\"
            >
            Reload Dashboard
          </button >
        </div >
      );
    }

    return this.props.children;
  }
}

// --- Tipos ---
interface Strategy {
  id: string;
  name: string;
  equity: number;
  balance: number;
  pnl: number;
  roi: number;
  active_ops: number;
  total_ops: number;
  paused: boolean;
}

interface Market {
  symbol: string;
  price: number;
  rsi: number;
  vrel: number;
  regime: string;
}

interface Operation {
  id: string;
  strategy_id: string;
  symbol: string;
  side: string;
  size: number;
  entry_price: number;
  current_price: number;
  pnl: number;
  pnl_pct: number;
  open_time: number;
}

interface HistoryItem {
  id: string;
  strategy_id: string;
  symbol: string;
  side: string;
  entry_price: number;
  exit_price: number;
  final_pnl: number;
  close_time: number;
}

interface BotState {
  global_equity: number;
  strategies: Strategy[];
  market: Market[];
  operations: Operation[];
  history: HistoryItem[];
}

// --- Componentes UI ---
const Card = ({ children, className = '' }: { children: React.ReactNode; className?: string }) => (
  <div className={\`glass rounded-xl p-6 border border-white/5 \${className}\`}>
    {children}
  </div>
);

const Badge = ({ children, variant = 'neutral' }: { children: React.ReactNode; variant?: 'success' | 'danger' | 'warning' | 'neutral' }) => {
  const colors = {
    success: 'bg-green-500/20 text-green-400 border-green-500/30',
    danger: 'bg-red-500/20 text-red-400 border-red-500/30',
    warning: 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30',
    neutral: 'bg-white/10 text-white/60 border-white/10'
  };
  return (
    <span className={\`px-2 py-1 rounded-full text-xs font-medium border \${colors[variant]}\`}>
      {children}
    </span>
  );
};

// --- Vistas ---

const DashboardView = ({ state, type }: { state: BotState; type: 'aggressive' | 'longterm' }) => {
  const allStrategies = state.strategies || [];
  const market = state.market || [];
  
  // Clasificación de estrategias
  const aggressiveIds = ['Aggressive', 'AggrCent', 'NetScalp', 'HybridElite', 'TrendADX', 'Cuchillo_caida'];
  const longtermIds = ['RollingDCA', 'RollingDCA_v2', 'RollingDCA_v3', 'Rol_dca_sh_v1', 'Rol_dca_sh_v2', 'Rol_dca_sh_v3'];
  
  const strategies = type === 'aggressive' 
    ? allStrategies.filter(s => aggressiveIds.includes(s.id))
    : allStrategies.filter(s => longtermIds.includes(s.id));
  
  const groupEquity = strategies.reduce((sum, s) => sum + (s.equity || 0), 0);
  const initialCapital = strategies.length * 500;
  const groupPnL = groupEquity - initialCapital;
  
  return (
    <div className=\"space-y-6\">
        {/* Dashboard Grid */}
          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">
            {/* Market Monitor */}
            <Card className=\"col-span-2\">
              <div className=\"flex justify-between items-center mb-6\">
                <h3 className=\"text-lg font-medium flex items-center gap-2\">
                  <Activity className=\"w-5 h-5 text-cyan-500\" />
                  Mercado
                </h3>
              </div>
              <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">
                {market.map((m) => (
                  <div key={m.symbol} className=\"p-4 rounded-lg bg-white/5 border border-white/5\">
                    <div className=\"flex justify-between items-start mb-2\">
                      <span className=\"font-bold\">{m.symbol}</span>
                      <Badge variant={m.rsi < 30 ? 'success' : m.rsi > 70 ? 'danger' : 'neutral'}>
                        RSI {m.rsi}
                      </Badge>
                    </div>
                    <div className=\"text-2xl font-mono\">{m.price?.toFixed(2) ?? '0.00'}</div>
                    <div className=\"text-xs text-gray-400 mt-1\">
                      VolRel: {m.vrel} | {m.regime}
                    </div>
                  </div>
                ))}
              </div>
            </Card>

            {/* Quick Stats */}
            <Card className=\"bg-gradient-to-br from-cyan-900/10 to-transparent border-cyan-500/10\">
               <h3 className=\"text-lg font-medium mb-4 text-cyan-400\">Rendimiento</h3>
               <div className=\"space-y-6\">
                 <div>
                    <div className=\"text-sm text-gray-400 mb-1\">Total PnL Estimado</div>
                    <div className={\`text-3xl font-mono \${(state.global_equity - 13*500) >= 0 ? 'text-green-400' : 'text-red-400'}\`}>
                        {((state.global_equity || 0) - (strategies.length * 500)).toFixed(2)} €
                    </div>
                 </div>
                 <div className=\"grid grid-cols-2 gap-4\">
                    <div className=\"p-3 rounded bg-black/20\">
                        <div className=\"text-xs text-gray-500\">Ops Activas</div>
                        <div className=\"text-xl font-bold\">
                            {strategies.reduce((acc, st) => acc + st.active_ops, 0)}
                        </div>
                    </div>
                    <div className=\"p-3 rounded bg-black/20\">
                        <div className=\"text-xs text-gray-500\">Estrategias</div>
                        <div className=\"text-xl font-bold\">
                            {strategies.length}
                        </div>
                    </div>
                 </div>
               </div>
            </Card>
          </div>

          {/* Strategies Grid */}
          <h2 className=\"text-2xl font-bold flex items-center gap-2 pt-4\">
            <TrendingUp className=\"w-6 h-6 text-cyan-500\" />
            Motores de Trading
          </h2>
          
          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6\">
            {strategies.map((strat) => (
              <Card key={strat.id} className=\"group hover:border-cyan-500/30 transition-all duration-300\">
                <div className=\"flex justify-between items-start mb-4\">
                  <div>
                    <h4 className=\"font-bold text-lg group-hover:text-cyan-400 transition-colors\">
                      {strat.id.replace('Strategy', '')}
                    </h4>
                    <span className=\"text-xs text-gray-500\">v2.1 Stable</span>
                  </div>
                  <div className={`w-3 h - 3 rounded - full \${ strat.paused ? 'bg-yellow-500' : 'bg-green-500 shadow-[0_0_10px_rgba(34,197,94,0.4)]' } \`} />
                </div>
                
                <div className=\"space-y-3 font-mono text-sm\">
                   <div className=\"flex justify-between\">
                     <span className=\"text-gray-500\">Equity</span>
                     <span className=\"text-white\">{strat.equity?.toFixed(2) ?? '0.00'} €</span>
                   </div>
                   <div className=\"flex justify-between\">
                     <span className=\"text-gray-500\">ROI</span>
                     <span className={\`\${strat.roi >= 0 ? 'text-green-400' : 'text-red-400'}\`}>
                       {strat.roi}%
                     </span>
                   </div>
                   <div className=\"flex justify-between pt-2 border-t border-white/5\">
                     <span className=\"text-gray-500\">Ops</span>
                     <span className=\"text-white\">{strat.active_ops} / {strat.total_ops}</span>
                   </div>
                </div>
              </Card>
            ))}
          </div>
    </div>
  );
};

const ActivityView = ({ state }: { state: BotState }) => {
    const history = state.history || [];
    
    return (
        <Card>
            <h2 className=\"text-xl font-bold mb-6 flex items-center gap-2\">
                <History className=\"w-5 h-5 text-purple-400\" />
                Historial de Operaciones
            </h2>
            <div className=\"overflow-x-auto\">
                <table className=\"w-full text-sm text-left\">
                    <thead className=\"text-xs text-gray-400 uppercase bg-white/5\">
                        <tr>
                            <th className=\"px-4 py-3\">Fecha</th>
                            <th className=\"px-4 py-3\">Estrategia</th>
                            <th className=\"px-4 py-3\">Par</th>
                            <th className=\"px-4 py-3\">Lado</th>
                            <th className=\"px-4 py-3 text-right\">Entrada</th>
                            <th className=\"px-4 py-3 text-right\">Salida</th>
                            <th className=\"px-4 py-3 text-right\">PnL</th>
                        </tr>
                    </thead>
                    <tbody>
                        {history.map((h, i) => (
                            <tr key={i} className=\"border-b border-white/5 hover:bg-white/5 transition-colors\">
                                <td className=\"px-4 py-3 font-mono\">
                                    {new Date((h.close_time || 0) * 1000).toLocaleString()}
                                </td>
                                <td className=\"px-4 py-3 text-gray-300\">{h.strategy_id}</td>
                                <td className=\"px-4 py-3 font-bold\">{h.symbol}</td>
                                <td className=\"px-4 py-3\">
                                    <Badge variant={(h.side || 'buy') === 'buy' ? 'success' : 'danger'}>{(h.side || '?').toUpperCase()}</Badge>
                                </td>
                                <td className=\"px-4 py-3 text-right font-mono\">{h.entry_price?.toFixed(2) ?? '0.00'}</td>
                                <td className=\"px-4 py-3 text-right font-mono\">{h.exit_price?.toFixed(2) ?? '0.00'}</td>
                                <td className={\`px-4 py-3 text-right font-bold \${(h.final_pnl || 0) >= 0 ? 'text-green-400' : 'text-red-400'}\`}>
                                    {h.final_pnl?.toFixed(2) ?? '0.00'} €
                                </td>
                            </tr>
                        ))}
                        {history.length === 0 && (
                            <tr>
                                <td colSpan={7} className=\"px-4 py-8 text-center text-gray-500\">
                                    No hay historial disponible
                                </td>
                            </tr>
                        )}
                    </tbody>
                </table>
            </div>
        </Card>
    );
};

const TradingView = ({ state }: { state: BotState }) => {
    const operations = state.operations || [];
    
    return (
        <Card>
            <h2 className=\"text-xl font-bold mb-6 flex items-center gap-2\">
                <Zap className=\"w-5 h-5 text-yellow-400\" />
                Operaciones Activas
            </h2>
            <div className=\"grid grid-cols-1 gap-4\">
                {operations.map((op, i) => (
                    <div key={i} className=\"bg-white/5 rounded-lg p-4 flex flex-col md:flex-row justify-between items-center border border-white/10\">
                        <div className=\"flex items-center gap-4 mb-4 md:mb-0\">
                            <div className={`p - 3 rounded - full \${ op.side === 'buy' ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400' } \`}>
                                {op.side === 'buy' ? 'LONG' : 'SHORT'}
                            </div>
                            <div>
                                <h4 className=\"font-bold text-lg\">{op.symbol}</h4>
                                <div className=\"text-xs text-gray-400\">{op.strategy_id}</div>
                            </div>
                        </div>
                        
                        <div className=\"flex gap-8 text-sm\">
                            <div className=\"text-center\">
                                <div className=\"text-gray-500 text-xs\">Entrada</div>
                                <div className=\"font-mono\">{op.entry_price?.toFixed(2) ?? '0.00'}</div>
                            </div>
                            <div className=\"text-center\">
                                <div className=\"text-gray-500 text-xs\">Actual</div>
                                <div className=\"font-mono\">{(op.current_price || op.entry_price || 0).toFixed(2)}</div>
                            </div>
                            <div className=\"text-center\">
                                <div className=\"text-gray-500 text-xs\">PnL Latente</div>
                                <div className={\`font-bold font-mono \${(op.pnl || 0) >= 0 ? 'text-green-400' : 'text-red-400'}\`}>
                                    {(op.pnl || 0).toFixed(2)} €
                                </div>
                            </div>
                        </div>
                    </div>
                ))}
                
                {operations.length === 0 && (
                    <div className=\"text-center py-12 text-gray-500 bg-white/5 rounded-lg border border-dashed border-white/10\">
                        Sin operaciones activas en este momento
                    </div>
                )}
            </div>
        </Card>
    );
};

const DashboardContent = () => {
  const [activeTab, setActiveTab] = useState('aggressive');
  const [state, setState] = useState<BotState | null>(null);
  const [loading, setLoading] = useState(true);
  const ws = useRef<WebSocket | null>(null);

  useEffect(() => {
    const connect = () => {
      const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
      const host = window.location.port === '5173' 
        ? '192.168.1.99:8000' 
        : window.location.host;
      
      const wsUrl = \`\${protocol}//\${host}/ws\`;
      ws.current = new WebSocket(wsUrl);

      ws.current.onmessage = (event) => {
        try {
          const data = JSON.parse(event.data);
          if (data.type === 'full_state' || data.global_equity !== undefined) {
            setState(data);
            setLoading(false);
          }
        } catch (e) { console.error(e); }
      };

      ws.current.onclose = () => {
         console.log(\"WS Closed. Retrying in 3s...\");
         setTimeout(connect, 3000);
      };
    };

    axios.get('/api/state').then(res => {
        if (res.data) { setState(res.data); setLoading(false); }
    }).catch(e => console.error(e));

    connect();
    return () => { ws.current?.close(); };
  }, []);

  if (loading) {
    return (
      <div className=\"min-h-screen bg-[#0a0a0a] flex items-center justify-center text-cyan-500\">
        <Activity className=\"w-12 h-12 animate-pulse\" />
        <span className=\"ml-4 font-mono\">CONECTANDO NUCLEO...</span>
      </div>
    );
  }

  // Protección extrema contra nulos
  const s = state || { global_equity: 0, strategies: [], market: [], operations: [], history: [] };

  return (
    <div className=\"min-h-screen bg-[#0a0a0a] text-white font-sans selection:bg-cyan-500/30\">
      
      {/* Sidebar */}
      <nav className=\"fixed left-0 top-0 h-full w-20 glass border-r border-white/5 flex flex-col items-center py-8 z-50\">
        <div className=\"mb-12 p-3 bg-cyan-500/10 rounded-xl border border-cyan-500/20 shadow-[0_0_15px_rgba(6,182,212,0.3)]\">
          <Zap className=\"w-6 h-6 text-cyan-400\" />
        </div>
        
        {['aggressive', 'longterm', 'trading', 'activity'].map((id) => (
          <button
            key={id}
            onClick={() => setActiveTab(id)}
            className={\`p-4 mb-4 rounded-xl transition-all duration-300 group relative \${
              activeTab === id ? 'bg-white/10 text-cyan-400' : 'text-gray-500 hover:text-white hover:bg-white/5'
            }\`}
          >
            {id === 'dashboard' && <Layout className=\"w-6 h-6\" />}
            {id === 'trading' && <TrendingUp className=\"w-6 h-6\" />}
            {id === 'activity' && <History className=\"w-6 h-6\" />}
            
            {activeTab === id && (
              <motion.div 
                layoutId=\"activeTab\"
                className=\"absolute inset-0 border border-cyan-500/30 rounded-xl\"
              />
            )}
          </button>
        ))}
      </nav>

      {/* Main Content */}
      <main className=\"pl-20 min-h-screen\">
        <div className=\"max-w-7xl mx-auto p-8\">
          
          {/* Header */}
          <header className=\"flex justify-between items-end mb-12\">
            <div>
              <h1 className=\"text-4xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-white to-gray-500 mb-2 capitalize\">
                {activeTab}
              </h1>
              <div className=\"flex items-center gap-2 text-gray-400 font-mono text-sm\">
                <span className=\"w-2 h-2 bg-green-500 rounded-full animate-pulse\" />
                SISTEMA EN LINEA
              </div>
            </div>
            
            <div className=\"text-right\">
              <div className=\"text-sm text-gray-400 mb-1\">EQUIDAD GLOBAL</div>
              <div className=\"text-5xl font-bold font-mono tracking-tighter text-cyan-400 drop-shadow-[0_0_20px_rgba(6,182,212,0.3)]\">
                {(s.global_equity || 0).toFixed(2)} €
              </div>
            </div>
          </header>

          <AnimatePresence mode=\"wait\">
            <motion.div
                key={activeTab}
                initial={{ opacity: 0, y: 10 }}
                animate={{ opacity: 1, y: 0 }}
                exit={{ opacity: 0, y: -10 }}
                transition={{ duration: 0.2 }}
            >
                {activeTab === 'aggressive' && <DashboardView state={s} type="aggressive" />}
                {activeTab === 'longterm' && <DashboardView state={s} type="longterm" />}
                {activeTab === 'trading' && <TradingView state={s} />}
                {activeTab === 'activity' && <ActivityView state={s} />}
            </motion.div>
          </AnimatePresence>

        </div>
      </main>
    </div>
  );
};

// Main App wrapped in ErrorBoundary
export default function App() {
  return (
    <ErrorBoundary>
      <DashboardContent />
    </ErrorBoundary>
  );
}
